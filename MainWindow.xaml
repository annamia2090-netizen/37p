<Window x:Class="пр37.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:пр37"
        mc:Ignorable="d"
        Title="Расчет заработной платы" Height="790" Width="850" MinHeight="550" MinWidth="750" WindowStartupLocation="CenterScreen">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="156*"/>
            <RowDefinition Height="114*"/>
            <RowDefinition Height="37*"/>
        </Grid.RowDefinitions>
        <Grid Grid.Row="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1*"/>
                <ColumnDefinition Width="1*"/>
            </Grid.ColumnDefinitions>
            <GroupBox Grid.Column="0" Header="ДАННЫЕ СОТРУДНИКА" Margin="5">
                <Grid Margin="10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="35"/>
                        <RowDefinition Height="35"/>
                        <RowDefinition Height="35"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="35"/>
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="100"/>
                        <ColumnDefinition Width="2*"/>
                    </Grid.ColumnDefinitions>
                    <Label Grid.Row="0" Grid.Column="0" Content="Фамилия:"/>
                    <TextBox x:Name="txtLastName" Grid.Row="0" Grid.Column="1" Margin="5"/>
                    <Label Grid.Row="1" Grid.Column="0" Content="Имя:"/>
                    <TextBox x:Name="txtFirstName" Grid.Row="1" Grid.Column="1" Margin="5"/>
                    <Label Grid.Row="2" Grid.Column="0" Content="Отчество:"/>
                    <TextBox x:Name="txtMiddleName" Grid.Row="2" Grid.Column="1" Margin="5"/>
                    <Label Grid.Row="3" Grid.Column="0" Content="Должность:" VerticalAlignment="Top" Margin="5,10,0,0"/>
                    <StackPanel Grid.Row="3" Grid.Column="1" Margin="5">
                        <RadioButton x:Name="rbAssistant" Content="Ассистент (3880 руб.)" GroupName="Position" Margin="5" Checked="rbPosition_Checked"/>
                        <RadioButton x:Name="rbTeacher" Content="Преподаватель (4268 руб.)" GroupName="Position" Margin="5" Checked="rbPosition_Checked"/>
                        <RadioButton x:Name="rbSeniorTeacher" Content="Старший преподаватель (5104 руб.)" GroupName="Position" Margin="5" Checked="rbPosition_Checked"/>
                        <RadioButton x:Name="rbDocent" Content="Доцент (5247 руб.)" GroupName="Position" Margin="5" Checked="rbPosition_Checked"/>
                        <RadioButton x:Name="rbProfessor" Content="Профессор (6003 руб.)" GroupName="Position" Margin="5" Checked="rbPosition_Checked"/>
                        <RadioButton x:Name="rbHeadOfDepartment" Content="Заведующий кафедрой (6463 руб.)" GroupName="Position" Margin="5" Checked="rbPosition_Checked"/>
                        <RadioButton x:Name="rbDean" Content="Декан факультета (6960 руб.)" GroupName="Position" Margin="5" Checked="rbPosition_Checked"/>
                    </StackPanel>
                    <Label Grid.Row="4" Grid.Column="0" Content="Оклад (руб.):"/>
                    <TextBox x:Name="tbSalary" Grid.Row="4" Grid.Column="1" IsReadOnly="True" Background="#E8E8E8" Margin="5"/>
                </Grid>
            </GroupBox>
            <GroupBox Grid.Column="1" Header="РЕЗУЛЬТАТ РАСЧЕТА" Margin="5">
                <Grid Margin="10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="35"/>
                        <RowDefinition Height="35"/>
                        <RowDefinition Height="35"/>
                        <RowDefinition Height="10"/>
                        <RowDefinition Height="40"/>
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="180"/>
                        <ColumnDefinition Width="2*"/>
                    </Grid.ColumnDefinitions>
                    <Label Grid.Row="0" Grid.Column="0" Content="Начисление:"/>
                    <TextBox x:Name="tbAccrual" Grid.Row="0" Grid.Column="1" IsReadOnly="True" Background="#F5F5F5" Margin="5"/>
                    <Label Grid.Row="1" Grid.Column="0" Content="Уральский коэффициент (15%):"/>
                    <TextBox x:Name="tbUral" Grid.Row="1" Grid.Column="1" IsReadOnly="True" Background="#F5F5F5" Margin="5"/>
                    <Label Grid.Row="2" Grid.Column="0" Content="Подоходный налог (13%):"/>
                    <TextBox x:Name="tbTax" Grid.Row="2" Grid.Column="1" IsReadOnly="True" Background="#F5F5F5" Margin="5"/>
                    <Label Grid.Row="4" Grid.Column="0" Content="К ВЫДАЧЕ:" FontWeight="Bold" Foreground="Green"/>
                    <TextBox x:Name="tbToPay" Grid.Row="4" Grid.Column="1" IsReadOnly="True" Background="#F5F5F5" Margin="5" FontWeight="Bold" Foreground="Green" FontSize="14"/>
                </Grid>
            </GroupBox>
        </Grid>
        <GroupBox Grid.Row="1" Header="НАДБАВКИ" Margin="5,10,5,10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="1*"/>
                    <ColumnDefinition Width="1*"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0" Margin="10">
                    <CheckBox x:Name="chkDocent" Content="Звание доцента (40%)" Margin="5" Height="30"/>
                    <CheckBox x:Name="chkHarm" Content="Вредность (12%)" Margin="5" Height="30"/>
                    <CheckBox x:Name="chkCabinet" Content="Заведование кабинетом (10% от ставки)" Margin="5" Height="30"/>
                    <CheckBox x:Name="chkNational" Content="Участие в национальном проекте (15%)" Margin="5" Height="30"/>
                </StackPanel>
                <StackPanel Grid.Column="1" Margin="10">
                    <CheckBox x:Name="chkCurator" Content="Куратор группы (20%)" Margin="5" Height="30"/>
                    <CheckBox x:Name="chkHonored" Content="Заслуженный учитель России (50%)" Margin="5" Height="30"/>
                    <CheckBox x:Name="chkCandidate" Content="Ученая степень кандидата наук (50%)" Margin="5" Height="30"/>
                    <CheckBox x:Name="chkDoctor" Content="Ученая степень доктора наук (70%)" Margin="5" Height="30"/>
                    <CheckBox x:Name="chkMethodLit" Content="Методическая литература (100 руб.)" Margin="5" Height="30"/>
                </StackPanel>
            </Grid>
        </GroupBox>
        <WrapPanel Grid.Row="2" HorizontalAlignment="Center" Margin="0,10,0,25" Width="545">
            <Button x:Name="btnCalculate" Content="РАССЧИТАТЬ" Width="120" Height="35" Margin="8" Background="#4CAF50" Foreground="White" Click="btnCalculate_Click"/>
            <Button x:Name="btnSave" Content="СОХРАНИТЬ" Width="120" Height="35" Margin="8" Background="#2196F3" Foreground="White" Click="btnSave_Click"/>
            <Button x:Name="btnClear" Content="ОЧИСТИТЬ" Width="120" Height="35" Margin="8" Background="#FF9800" Foreground="White" Click="btnClear_Click"/>
            <Button x:Name="btnExit" Content="ВЫХОД" Width="120" Height="35" Margin="8" Background="#F44336" Foreground="White" Click="btnExit_Click"/>
        </WrapPanel>
    </Grid>
</Window>
